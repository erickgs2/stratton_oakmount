generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Trade {
  id            String   @id @default(cuid())
  symbol        String
  market        String   // "MX" | "USA"
  action        String   // "buy" | "sell" | "hold"
  quantity      Float
  price         Float
  currency      String   // "MXN" | "USD"
  reason        String
  ibkrOrderId   String?
  source        String   @default("agent") // "agent" | "manual"
  placedByEmail String?  // set for source:"manual"; null for source:"agent"
  createdAt     DateTime @default(now())
}

model BotConfig {
  id                  String   @id @default(cuid())
  market              String   @unique // "MX" | "USA"
  symbols             String[]
  capitalLimit        Float
  intervalMin         Int
  confidenceThreshold Float    @default(0.65)
  takeProfitPct       Float    @default(1.5)   // percentage points, e.g. 1.5 = 1.5%
  stopLossPct         Float    @default(1.0)   // percentage points, e.g. 1.0 = 1.0%
  feeEstimatePct      Float    @default(0.10)  // neutral fallback; real per-market defaults (MX 0.30 / USA 0.05) applied by app layer + migration backfill
  tpSlBypassEnabled   Boolean  @default(false) // when true, take-profit/stop-loss exits fire deterministically without a Claude call
  isActive            Boolean  @default(false)
  updatedAt           DateTime @updatedAt
}

model AgentLog {
  id         String   @id @default(cuid())
  symbol     String
  market     String
  marketData Json
  response   Json
  executed   Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model BotLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  level     String
  event     String
  market    String?
  symbol    String?
  message   String
  meta      Json?
}

model AppSettings {
  id            String  @id @default("singleton")
  ibkrAccountId String?
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String
  canEditConfig  Boolean  @default(false)
  canManualTrade Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model CryptoPriceSnapshot {
  id         String   @id @default(cuid())
  book       String   // Bitso book, e.g. "btc_mxn"
  price      Float
  recordedAt DateTime @default(now())

  @@index([book, recordedAt])
}
