# PostgreSQL — use host.docker.internal so the backend container reaches the Pi's Postgres
DATABASE_URL="postgresql://master@host.docker.internal:5432/stratton_oakmont"

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# DataBursátil
DATABURSATIL_TOKEN=your_token_here

# IBKR Client Portal Gateway (running on the Pi host at port 5001)
IBKR_GATEWAY_URL=https://host.docker.internal:5001/v1/api
IBKR_ACCOUNT_ID=your_account_id

# CORS — set to your DuckDNS hostname so the backend accepts requests from the web container
# In production via nginx proxy this is not strictly needed, but keep it for safety
CORS_ORIGIN=http://your-subdomain.duckdns.org
